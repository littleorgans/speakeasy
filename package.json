{
  "name": "speak-easy",
  "private": true,
  "version": "0.0.0",
  "description": "Cascaded speech-to-speech engine (STT -> LLM -> TTS). Local-first, sub-200ms finalization.",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "typecheck": "pnpm --filter @speakeasy/speech-io typecheck",
    "test": "pnpm --filter @speakeasy/speech-io test",
    "bench": "node packages/speech-io/src/bench/run.ts",
    "demo": "node packages/speech-io/src/demo/ptt.ts",
    "tts": "node packages/speech-io/src/tts/run.ts"
  }
}
